{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",

    "WEB_APP_URL",
    "NEXT_PUBLIC_WEB_APP_URL",

    "RESEND_API_KEY",
    "EMAIL_FROM",

    "POLAR_ACCESS_TOKEN",
    "POLAR_WEBHOOK_SECRET",
    "POLAR_FREE_PRODUCT_ID",
    "POLAR_FAMILY_PRODUCT_ID",
    "POLAR_PREMIUM_PRODUCT_ID",

    "JWT_SECRET",

    "REDIS_URL",
    "REDISHOST",
    "REDISPASSWORD",
    "REDISUSER",
    "REDIS_PASSWORD",
    "REDISPORT",
    "REDIS_PUBLIC_URL"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
